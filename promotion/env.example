# 环境变量配置模板
# 复制为 .env 并填入真实值

# ============================================
# Twitter API (optional)
# 申请: https://developer.twitter.com
# ============================================
TWITTER_BEARER="your_bearer_token_here"
TWITTER_USER_ID="your_user_id_here"

# ============================================
# Discord Bot (optional)
# 申请: https://discord.com/developers/applications
# ============================================
DISCORD_BOT_TOKEN="your_bot_token_here"
DISCORD_CHANNEL_ID="your_channel_id_here"

# ============================================
# Reddit API (optional)
# 申请: https://www.reddit.com/prefs/apps
# ============================================
REDDIT_USERNAME="your_reddit_username"
REDDIT_PASSWORD="your_reddit_password"
REDDIT_CLIENT_ID="your_client_id"
REDDIT_CLIENT_SECRET="your_client_secret"

# ============================================
# V2EX (optional)
# 使用网站用户名/密码
# ============================================
V2EX_USERNAME="your_v2ex_username"
V2EX_PASSWORD="your_v2ex_password"

# ============================================
# ClawHub & SkillPay
# ============================================
CLAWHUB_SKILL_ID="k97f8tdg1cvjjjcevwy8mjmw6n82av75"
SKILLPAY_API_KEY="sk_..."
SKILLPAY_SKILL_ID="skill_..."

# ============================================
# GitHub Token (optional, 提高 API 配额)
# 申请: https://github.com/settings/tokens
# ============================================
GITHUB_TOKEN="ghp_..."

# ============================================
# Webhook (optional, 用于数据推送)
# ============================================
WEBHOOK_URL="https://your-webhook.com/collect"

# ============================================
# Skill 配置
# ============================================
TWEET_MONITOR_PRO_SKILL_ID="${CLAWHUB_SKILL_ID}"
# 或直接设置: TWEET_MONITOR_PRO_SKILL_ID="your_skill_id"
